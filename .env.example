# Web Push (Phase 3) — cues that fire with the app fully closed.
# Generate a keypair once:  npx web-push generate-vapid-keys
# Leave unset to run without push: in-page cues + vibration still work.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact for push services (mailto: or https: URL).
VAPID_SUBJECT=mailto:you@example.com

# Anchor Coach — the conversational AI layer (Claude). Get a key at
# https://platform.claude.com. Leave unset to run without the coach:
# the feature hides itself and everything else works.
ANTHROPIC_API_KEY=
